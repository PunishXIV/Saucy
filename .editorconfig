# EzIPC assigns delegate fields via reflection; readonly/initonly breaks runtime init.
[Saucy/IPC/Vnavmesh.cs]
dotnet_diagnostic.IDE0044.severity = none

[Saucy/IPC/BossMod.cs]
dotnet_diagnostic.IDE0044.severity = none
