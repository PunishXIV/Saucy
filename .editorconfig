root = true

# Saucy C# style: dotnet format (whitespace) + IDE analyzers (Debug EnforceCodeStyleInBuild).
# After edits: dotnet format Saucy/Saucy.csproj
# Compact object initializers ({ A = 1, B = 2 }). Wrapped expression bodies: ") =>" on the declaration line, body on the next.

[*.cs]
indent_style = space
indent_size = 4
tab_width = 4
end_of_line = crlf
trim_trailing_whitespace = true
insert_final_newline = true
dotnet_code_quality.api_surface = all
dotnet_code_quality.CA1826.exclude_ordefault_methods = true
dotnet_code_quality.CA1707.api_surface = public, internal
dotnet_diagnostic.CA1000.severity = none
dotnet_diagnostic.CA1002.severity = none
dotnet_diagnostic.CA1003.severity = none
dotnet_diagnostic.CA1028.severity = none
dotnet_diagnostic.CA1030.severity = none
